  "scripts": {
    "start": "node app.js",
    "prodlocal": "nodemon -r dotenv/config app.js dotenv_config_path=./.env",
    "dev": "nodemon -r dotenv/config app.js dotenv_config_path=./dev.env",
    "gallery": "nodemon ./views/beta/gallery.js",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles": [
      "./__tests__/setup.js"
    ],
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  },
  "overrides": {
    "undici": "^5.28.4"
  }
