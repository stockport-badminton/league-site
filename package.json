    "body-parser": "^1.20.3",
    "bootstrap": "^4.1.1",
    "cheerio": "^1.2.0",
    "compression": "^1.7.4",
    "connect-ensure-login": "^0.1.1",
    "connect-pg-simple": "^10.0.0",
    "cookie-parser": "^1.4.3",
    "docx": "^8.2.3",
    "dotenv": "^10.0.0",
    "ejs": "^3.1.8",
    "exceljs": "^4.4.0",
    "express": "^4.21.2",
    "express-jwt": "^6.0.0",
    "express-jwt-authz": "^1.0.0",
    "express-session": "^1.15.6",
    "express-validator": "^6.14.2",
