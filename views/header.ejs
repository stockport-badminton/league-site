    window.sentryOnLoad = function () {
      // in here, Sentry is ensured to be loaded & fully available

      // Session Replay is quota-limited (50/month once the free trial ends), so
      // only record it where it earns its keep, and never spend the budget on
      // noise. A replay is enabled only when ALL of these hold:
      //   - production (never local/dev testing)
      //   - a results-entry or stats page (the only flows we want to watch)
      //   - the viewer is NOT the site admin (sole superadmin, who tests these
      //     daily and can watch locally)
      // (Logged-in-only is already guaranteed — this whole block only renders
      // for a logged-in user.) Error/console capture below still runs on every
      // page for every logged-in user; only the replay is gated.
      var REPLAY_PATHS = [
        /^\/email-scorecard/,
        /^\/messer-scorecard-beta/,
        /^\/populated-messer-scorecard/,
        /^\/player-stats/,
        /^\/pair-stats/
      ];
      var isProd = <%= process.env.NODE_ENV === 'production' ? 'true' : 'false' %>;
      var isSiteAdmin = <%= (user._json && user._json['https://my-app.example.com/role'] === 'superadmin') ? 'true' : 'false' %>;
      var onReplayPath = REPLAY_PATHS.some(function (re) { return re.test(window.location.pathname); });
      var enableReplay = isProd && !isSiteAdmin && onReplayPath;

      var integrations = [];
      if (enableReplay) {
        integrations.push(Sentry.replayIntegration({
          maskAllText: false,
          blockAllMedia: false
        }));
      }

      Sentry.init({
        dsn: "https://41a5442332daa78ebc9dba9dfe8da392@o4508301910540288.ingest.de.sentry.io/4508301914800208",
        // Off (0) on every non-eligible page. On eligible pages: keep a light
        // sample of normal sessions, and always keep one that hits an error
        // (errors are rare and the most useful, so they cost little quota).
        replaysSessionSampleRate: enableReplay ? 0.1 : 0,
        replaysOnErrorSampleRate: enableReplay ? 1.0 : 0,
        integrations: integrations,
      });


      Sentry.lazyLoadIntegration("captureConsoleIntegration").then(
        (integration) => {
          // Only forward real errors — not console.log/info/debug/warn — so
          // stray dev logging doesn't flood Sentry (and the free-tier quota).
          Sentry.addIntegration(integration({ levels: ['error'] }));
        },
      );
      Sentry.setUser({ id: '<%= user.user_id %>' });
    }
      </script>
