<%- include('../header.ejs') %>
<%- include('../nav.ejs') %>

<h1>Tameside Fixtures 2026/27</h1>

<% if (typeof fixturesOutput !== 'undefined') { %>
<div class="table-responsive">
    <table class="table" id="results-table">
        <thead>
            <tr>
                <th>Date</th>
                <th>Home Team</th>
                <th>Away Team</th>
                <th>Division</th>
            </tr>
        </thead>
        <% fixturesOutput.forEach(function(dateRow){ %>
            <% if (typeof dateRow.fixtures !== 'undefined') { dateRow.fixtures.forEach(function(fixture){ %>
            <tr>
                <td><%= dateRow.date %></td>
                <td>
                    <% if(dateRow.xmas){ %>XMAS<br /><% } %>
                    <% if(dateRow.easter){ %>EASTER<br /><% } %>
                    <% if(dateRow.lewisshield){ %>LEWIS SHIELD<br /><% } %>
                    <%= fixture.homeTeam %>
                </td>
                <td><%= fixture.awayTeam %></td>
                <td><%= fixture.division %></td>
            </tr>
            <% }) } %>
        <% }) %>
    </table>
</div>
<% } %>

<hr />
<h2>Division 1 — Spreadsheet View</h2>
<p>
    <button id="dlDiv1Html" class="btn btn-primary btn-sm">Download Div 1 HTML</button>
    <button id="dlDiv1Csv" class="btn btn-secondary btn-sm">Download Div 1 CSV</button>
</p>
<div id="divOneOutput"></div>

<hr />
<h2>Division 2 — Spreadsheet View</h2>
<p>
    <button id="dlDiv2Html" class="btn btn-primary btn-sm">Download Div 2 HTML</button>
    <button id="dlDiv2Csv" class="btn btn-secondary btn-sm">Download Div 2 CSV</button>
</p>
<div id="divTwoOutput"></div>

<%- include('../footer.ejs') %>
<%- include('../datatables.ejs') %>

<script>
    const xmasDate = new Date(2026, 11, 25);
    const easterDate = new Date(2027, 2, 28);
    const seasonStartDate = new Date(2026, 8, 1);
    const seasonEndDate = new Date(2027, 4, 1);

    var nearEaster = function(currentDate) {
        var easterBreakStart = new Date(+easterDate);
        var easterBreakEnd = new Date(+easterDate);
        easterBreakStart.setDate(easterDate.getDate() - 4);
        easterBreakEnd.setDate(easterDate.getDate() + 2);
        return currentDate > easterBreakStart && currentDate < easterBreakEnd;
    };

    var nearXmas = function(currentDate) {
        var xmasBreakStart = new Date(+xmasDate);
        xmasBreakStart.setDate(xmasDate.getDate() - xmasDate.getDay());
        var xmasBreakEnd = new Date(+xmasBreakStart);
        xmasBreakEnd.setDate(xmasBreakStart.getDate() + 14);
        return currentDate >= xmasBreakStart && currentDate <= xmasBreakEnd;
    };

    var islewisShieldWeek = function(currentDate) {
        var xmasBreakStart = new Date(+xmasDate);
        xmasBreakStart.setDate(xmasDate.getDate() - xmasDate.getDay());
        var xmasBreakEnd = new Date(+xmasBreakStart);
        xmasBreakEnd.setDate(xmasBreakStart.getDate() + 14);
        var lewisShieldBreak1Start = new Date(+xmasBreakEnd);
        var lewisShieldBreak1End = new Date(+lewisShieldBreak1Start);
        lewisShieldBreak1End.setDate(lewisShieldBreak1Start.getDate() + 21);
        var lewisShieldBreak2Start = new Date(+lewisShieldBreak1End);
        lewisShieldBreak2Start.setDate(lewisShieldBreak1End.getDate() + 21);
        var lewisShieldBreak2End = new Date(+lewisShieldBreak2Start);
        lewisShieldBreak2End.setDate(lewisShieldBreak2Start.getDate() + 14);
        var easterBreakStart = new Date(+easterDate);
        var easterBreakEnd = new Date(+easterDate);
        easterBreakStart.setDate(easterDate.getDate() - 7);
        easterBreakEnd.setDate(easterDate.getDate() + 7);
        var lewisShieldBreak3Start;
        if (seasonEndDate - easterBreakEnd < (14 * 86400000)) {
            lewisShieldBreak3Start = new Date(+easterBreakStart);
            lewisShieldBreak3Start.setDate(easterBreakStart.getDate() - 14);
        } else {
            lewisShieldBreak3Start = new Date(+easterBreakEnd);
        }
        var lewisShieldBreak3End = new Date(+lewisShieldBreak3Start);
        lewisShieldBreak3End.setDate(lewisShieldBreak3Start.getDate() + 14);
        return (
            (currentDate > lewisShieldBreak1Start && currentDate < lewisShieldBreak1End) ||
            (currentDate > lewisShieldBreak2Start && currentDate < lewisShieldBreak2End) ||
            (currentDate > lewisShieldBreak3Start && currentDate < lewisShieldBreak3End)
        );
    };

    function buildDivisionTables(fixtures, divisionTeams, startDate) {
        var weekdays = ["Sun", "Mon", "Tue", "Wed", "Thu", "Fri", "Sat"];
        var htmlString = "<table border=\"1\" cellpadding=\"4\" cellspacing=\"0\">\n";
        var csvReport = [];

        for (var i = 0; i < 3; i++) {
            var csvRow = [];
            htmlString += "<tr>\n<td>";
            csvRow.push(i === 2 ? "Match day" : " ");
            csvRow.push(" ");
            for (var team in divisionTeams) {
                if (i === 0) csvRow.push(" ");
                else if (i === 1) csvRow.push(divisionTeams[team].name);
                else csvRow.push(divisionTeams[team].homeNight);
            }
            csvReport.push(csvRow.join(","));
            htmlString += csvRow.join("</td>\n<td>");
            htmlString += "</td></tr>\n";
        }

        var day = new Date(startDate);
        while (day <= seasonEndDate) {
            var csvRow = [];
            htmlString += "<tr>\n<td>";
            csvRow.push(weekdays[day.getDay()]);
            csvRow.push(day.getDate() + "/" + (day.getMonth() + 1) + "/" + day.getFullYear());
            for (var team in divisionTeams) {
                if (nearXmas(day)) {
                    csvRow.push(day.getDay() === 3 ? "XMAS BREAK" : "X");
                } else if (nearEaster(day)) {
                    csvRow.push(day.getDay() === 3 ? "EASTER BREAK" : "X");
                } else if (islewisShieldWeek(day)) {
                    csvRow.push(day.getDay() === 3 ? "LEWIS SHIELD" : "X");
                } else {
                    var dayTime = day.getTime();
                    var todaysFixtures = fixtures.filter(function(f) {
                        return new Date(f.date + " 00:00:00").getTime() === dayTime;
                    });
                    var cell = " ";
                    for (var k = 0; k < todaysFixtures.length; k++) {
                        if (todaysFixtures[k].homeTeam === divisionTeams[team].name) {
                            cell = "<strong>" + todaysFixtures[k].homeTeam + "</strong>";
                            break;
                        } else if (todaysFixtures[k].awayTeam === divisionTeams[team].name) {
                            cell = "<em>" + todaysFixtures[k].awayTeam + "</em>";
                            break;
                        }
                    }
                    csvRow.push(cell);
                }
            }
            csvReport.push(csvRow.join(","));
            htmlString += csvRow.join("</td>\n<td>");
            htmlString += "</td>\n</tr>\n";
            day.setDate(day.getDate() + 1);
        }
        htmlString += "</table>\n";

        var gridHtml = "<table border=\"1\" cellpadding=\"4\" cellspacing=\"0\">\n<tr><td>&nbsp;</td>";
        for (var team in divisionTeams) {
            gridHtml += "<td>" + divisionTeams[team].name + "</td>";
        }
        gridHtml += "</tr>";
        for (var homeTeam in divisionTeams) {
            gridHtml += "<tr><td>" + divisionTeams[homeTeam].name + "</td>";
            for (var awayTeam in divisionTeams) {
                if (homeTeam === awayTeam) {
                    gridHtml += "<td>&nbsp;</td>";
                } else {
                    var cross = fixtures.filter(function(f) {
                        return f.homeTeam === divisionTeams[homeTeam].name && f.awayTeam === divisionTeams[awayTeam].name;
                    });
                    gridHtml += cross.length
                        ? "<td>" + cross[0].date.replace(/^(\d{1,2})-(\d{1,2})-(\d{4})$/, "$2/$1/$3") + "</td>"
                        : "<td>0/0/0000</td>";
                }
            }
            gridHtml += "</tr>";
        }
        gridHtml += "</table>";

        return { htmlString: htmlString, gridHtml: gridHtml, csvReport: csvReport };
    }

    function downloadFile(content, filename, type) {
        var blob = new Blob([content], { type: type });
        var url = URL.createObjectURL(blob);
        var a = document.createElement('a');
        a.href = url;
        a.download = filename;
        document.body.appendChild(a);
        a.click();
        document.body.removeChild(a);
        URL.revokeObjectURL(url);
    }

    var div1Fixtures = <%- divOneFixtures %>;
    var div1Teams = <%- divOneTeams %>;
    var div1 = buildDivisionTables(div1Fixtures, div1Teams, seasonStartDate);
    document.getElementById('divOneOutput').innerHTML = div1.htmlString + div1.gridHtml;

    document.getElementById('dlDiv1Html').addEventListener('click', function() {
        downloadFile('<html><head></head><body>' + div1.htmlString + div1.gridHtml + '</body></html>', 'division1-fixtures.html', 'text/html');
    });
    document.getElementById('dlDiv1Csv').addEventListener('click', function() {
        downloadFile(div1.csvReport.join('\r\n'), 'division1-fixtures.csv', 'text/csv');
    });

    var div2Fixtures = <%- divTwoFixtures %>;
    var div2Teams = <%- divTwoTeams %>;
    var div2 = buildDivisionTables(div2Fixtures, div2Teams, seasonStartDate);
    document.getElementById('divTwoOutput').innerHTML = div2.htmlString + div2.gridHtml;

    document.getElementById('dlDiv2Html').addEventListener('click', function() {
        downloadFile('<html><head></head><body>' + div2.htmlString + div2.gridHtml + '</body></html>', 'division2-fixtures.html', 'text/html');
    });
    document.getElementById('dlDiv2Csv').addEventListener('click', function() {
        downloadFile(div2.csvReport.join('\r\n'), 'division2-fixtures.csv', 'text/csv');
    });
</script>

</body>
</html>
