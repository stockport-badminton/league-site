<%- include('header.ejs') %>
<%- include('nav.ejs') %>

<div class="modal-dialog">
  <h3>Approve New Signup</h3>
  <p><strong>Email:</strong> <%= authUser.email %></p>
  <% if (authUser.name && authUser.name !== authUser.email) { %>
    <p><strong>Name:</strong> <%= authUser.name %></p>
  <% } %>

  <% if (existingLink) { %>
    <div class="alert alert-warning">
      This email is already linked to <strong><%= existingLink.first_name %> <%= existingLink.family_name %></strong>
      (role: <%= existingLink.role || 'none' %><% if (existingLink.messerAdmin) { %>, messer admin<% } %>, club: <%= existingLink.clubName %>).
      Submitting below will link this account to whichever player you pick instead.
    </div>
  <% } %>

  <form method="post" action="/approve-user/<%= encodeURIComponent(userId) %>">
    <div class="form-group" style="position:relative;">
      <label for="playerSearch">Search for a player to link this account to</label>
      <input type="text" class="form-control" id="playerSearch" placeholder="Start typing a name…" autocomplete="off">
      <div id="playerSearchResults" class="list-group" style="display:none; position:absolute; z-index:10; width:100%; max-height:260px; overflow-y:auto;"></div>
    </div>
    <input type="hidden" name="playerId" id="playerId">
    <div id="selectedPlayer" class="form-group" style="display:none;">
      Selected: <strong id="selectedPlayerName"></strong>
      <button type="button" id="clearPlayer" class="btn btn-sm btn-link">change</button>
    </div>

    <div class="form-group">
      <label for="role">Site Role</label>
      <select name="role" id="role" class="form-control">
        <option value="">None</option>
        <option value="admin">Admin (own club)</option>
        <option value="superadmin">Superadmin (all clubs)</option>
      </select>
      <label for="messerAdmin">Messer Admin</label>
      <input type="checkbox" id="messerAdmin" name="messerAdmin" value="1">
    </div>

    <button type="submit" class="btn btn-primary" id="submitBtn" disabled>Approve &amp; Assign</button>
  </form>
</div>

<script>
  (function() {
    var searchInput = document.getElementById('playerSearch');
    var searchResult = document.getElementById('playerSearchResults');
    var playerIdInput = document.getElementById('playerId');
    var selectedPlayerDiv = document.getElementById('selectedPlayer');
    var selectedPlayerName = document.getElementById('selectedPlayerName');
    var clearBtn = document.getElementById('clearPlayer');
    var submitBtn = document.getElementById('submitBtn');
    var searchTimer;

    function runSearch() {
      var q = searchInput.value.trim();
      if (q.length < 2) { searchResult.style.display = 'none'; return; }

      fetch('/api/players/search?q=' + encodeURIComponent(q))
        .then(function(r) { return r.json(); })
        .then(function(players) {
          searchResult.innerHTML = '';
          if (players.length === 0) { searchResult.style.display = 'none'; return; }
          players.forEach(function(p) {
            var item = document.createElement('a');
            item.href = '#';
            item.className = 'list-group-item list-group-item-action py-1 small';
            var strong = document.createElement('strong');
            strong.textContent = p.name;
            var span = document.createElement('span');
            span.className = 'text-muted';
            span.textContent = p.teamName ? ' — ' + p.teamName : '';
            item.appendChild(strong);
            item.appendChild(span);
            item.addEventListener('click', function(e) {
              e.preventDefault();
              playerIdInput.value = p.id;
              selectedPlayerName.textContent = p.name + (p.teamName ? ' (' + p.teamName + ')' : '');
              selectedPlayerDiv.style.display = 'block';
              searchInput.value = '';
              searchResult.style.display = 'none';
              submitBtn.disabled = false;
            });
            searchResult.appendChild(item);
          });
          searchResult.style.display = 'block';
        });
    }

    searchInput.addEventListener('input', function() {
      clearTimeout(searchTimer);
      searchTimer = setTimeout(runSearch, 250);
    });

    clearBtn.addEventListener('click', function() {
      playerIdInput.value = '';
      selectedPlayerDiv.style.display = 'none';
      submitBtn.disabled = true;
    });
  })();
</script>

<%- include('footer.ejs') %>
